# scripts/e2e/.env.e2e.example
# Copy to .env.e2e and fill with REAL values. .env.e2e is gitignored.
#
# WHY: setup.ps1 reads these vars to provision the tenant in the bridge DB
# (via `bridge tenant add`) and to exercise the Chatwoot REST API in smoke.ps1.
# All values must point to real, reachable services BEFORE running setup.ps1.

# ---- megaAPI (instância externa já pareada com WhatsApp) ----
# Base URL. NÃO inclua trailing slash. Exemplo: https://api.megaapi.com.br
MEGAAPI_HOST=https://api.megaapi.com.br

# Instance ID da sessão WhatsApp pareada
MEGAAPI_INSTANCE=replace-me-instance-id

# Bearer token da instância (gerado no dashboard megaAPI)
MEGAAPI_TOKEN=replace-me-bearer

# ---- Chatwoot local (containers chatwoot-dev-*) ----
# Bridge roda em docker-compose `default` network e precisa alcançar Chatwoot
# (chatwoot-dev_default network). host.docker.internal funciona no Docker
# Desktop Windows/macOS e resolve para o host, que publica Chatwoot em :3000.
CHATWOOT_URL=http://host.docker.internal:3000

# api_access_token do usuário agente. Obtenha em:
#   Chatwoot → Profile Settings → Access Token → copy
CHATWOOT_TOKEN=replace-me-cw-api-token

# Account ID (geralmente 1 em instância dev nova)
CHATWOOT_ACCOUNT=1

# Inbox ID criado como "API channel" (Settings → Inboxes → Add Inbox → API)
CHATWOOT_INBOX=1

# ---- Tenant a provisionar no bridge ----
# Slug deve casar com regex ^[a-z0-9][a-z0-9-]{2,63}$
TENANT_SLUG=e2e-teste

# ---- Bridge stack (host port mappings) ----
# Defaults locais já evitam conflito comum (8080/5432 frequentemente ocupados).
# Bridge HTTP exposto ao host nesta porta — Cloudflared tunnel aponta pra ela.
BRIDGE_HOST_PORT=8090

# Postgres do bridge exposto ao host nesta porta (watch.ps1 usa para psql).
POSTGRES_HOST_PORT=5433

# Master key AES-256-GCM (32 bytes base64). Gere uma vez:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
# ou: openssl rand -base64 32
MASTER_KEY=replace-me-32-bytes-base64
