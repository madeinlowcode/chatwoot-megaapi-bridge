# Copy to .env (chmod 600) and fill in real values.

# === Required ===

# Master key for AES-GCM at-rest encryption (32 bytes, base64-encoded).
# Generate with: openssl rand -base64 32
MASTER_KEY=

# Postgres connection string used by the bridge.
DATABASE_URL=postgres://bridge:bridge@db:5432/bridge?sslmode=disable

# === Database (used by docker-compose) ===

POSTGRES_USER=bridge
POSTGRES_PASSWORD=bridge
POSTGRES_DB=bridge
POSTGRES_PORT=5432

# === Bridge ===

BRIDGE_PORT=8080
BRIDGE_IMAGE=bridge:latest
LOG_LEVEL=info
